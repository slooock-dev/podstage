# podstage — keep streaming input devices away from the desktop.
#
# Sunshine (inside the runtime container) creates virtual evdev devices for
# the Moonlight client's input. Without this rule they land on seat0 and the
# DESKTOP receives the client's input. Pinning them to seat9 makes cage
# (running on seat9 via its libseat shim) pick them up exclusively — and cage
# never touches the real desktop input devices either.
#
# Name matching matters: Sunshine's keyboard/mouse/touch devices are called
# "Mouse/Keyboard/Touch/Pen passthrough" — hence the *passthrough* pattern.
#
# Steam Input's OWN virtual gamepad (Valve vendor 0x28de, e.g. "Microsoft
# X-Box 360 pad 0") keeps its native name — Steam creates and feeds it itself
# on the real uinput, and any renaming/proxying breaks it. Pin it to seat9 by
# vendor id instead: seats only matter to libinput/compositors, Steam/SDL read
# evdev directly, so the pin is harmless for Steam — and it keeps the
# container's fake-udev monitor fast (every container-created device carries
# ID_SEAT, so the shim's ID_SEAT retry converges immediately). A device
# spoofing this vendor id lands on seat9 too — away from the desktop seat.
#
# MODE=0600 (no GROUP): access for the rootless container is granted purely
# via the per-user OWNER rule (71-podstage-input-owner.rules, generated by
# `podstage setup`) — group membership does not map through the rootless user
# namespace, owner-uid does.
#
# Install (root, once — `podstage setup` prints/runs this):
#   sudo install -m 644 host/99-podstage-virtual-inputs.rules /etc/udev/rules.d/
#   sudo udevadm control --reload
SUBSYSTEMS=="input", ATTRS{name}=="Sunshine*", ENV{ID_SEAT}="seat9", MODE="0600"
SUBSYSTEMS=="input", ATTRS{name}=="Wolf*", ENV{ID_SEAT}="seat9", MODE="0600"
SUBSYSTEMS=="input", ATTRS{name}=="*passthrough*", ENV{ID_SEAT}="seat9", MODE="0600"
SUBSYSTEMS=="input", ATTRS{id/vendor}=="28de", ENV{ID_SEAT}="seat9", MODE="0600"
